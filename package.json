{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "amber",
  "version": "0.0.0",
  "description": "Back up Git repositories and their full forge metadata — issues, PRs, releases, labels — not just the git history.",
  "keywords": [
    "archive",
    "backup",
    "cli",
    "git",
    "github",
    "kirchdev",
    "mirror",
    "nodejs",
    "octokit",
    "pnpm"
  ],
  "homepage": "https://github.com/TitusKirch/amber#readme",
  "bugs": {
    "url": "https://github.com/TitusKirch/amber/issues"
  },
  "license": "MIT",
  "author": "Titus Kirch <titus.kirch@kirch.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TitusKirch/amber.git"
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "check": "pnpm lint && pnpm format",
    "check:fix": "pnpm lint:fix && pnpm format:fix",
    "taze": "taze",
    "taze:w": "taze -w",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "taze": "^19.14.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2"
}
